# true: use the offline demo file. false: use football-data.org only.
USE_SAMPLE_DATA=true
FOOTBALL_DATA_API_KEY=
FOOTBALL_DATA_BASE_URL=https://api.football-data.org/v4
FOOTBALL_DATA_COMPETITION=WC

DATABASE_PATH=data/fifa2026.db
TEAM_STRENGTH_PATH=data/team_strength.json
FIXTURES_PATH=data/sample_fixtures.json
REQUEST_TIMEOUT=15

# Optional: `send` prints a preview when these are blank.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
